# dev/tests/.env.example
# Kopieren zu tests/.env und Werte für die Zielinstanz eintragen

# --- Instanz ---
BASE_URL=https://dev.muxd.de

# --- Test-User Credentials ---
ADMIN_USER=
ADMIN_PASS=
AUTHOR_USER=
AUTHOR_PASS=
SUBSCRIBER_USER=
SUBSCRIBER_PASS=
BUSINESS_PARTNER_USER=
BUSINESS_PARTNER_PASS=

# --- Instanz-spezifische URLs ---
# Login-Seite (vom Force-Login-Plugin freigeschaltet)
LOGIN_PATH=/member-login
# Hauptfeed nach dem Login
HOME_PATH=/
# Eine weitere Feed-URL zum Testen des Kategorie-Wechsels
FEED_PATH=/miteinander
# URL der Benutzerverwaltung (nur für Admin sichtbar)
USER_MGMT_PATH=/user-management
# URL zum Post-Erstellen
CREATE_POST_PATH=/uploading

# --- Instanz-spezifische Selektoren (nur ändern wenn nötig) ---
# CSS-Selektor für Posts im Feed
FEED_POST_SELECTOR=.post-row
# Text/Selector für "Mehr laden"-Button
# LOAD_MORE_SELECTOR: dotenv liest # als Kommentar-Zeichen, daher ist #more_posts der Fallback im Code
# Nur setzen wenn die Instanz einen anderen Selektor hat (ohne führendes #):
# Selektor für Benutzerverwaltungs-Link im Menü
USER_MGMT_SELECTOR=a:has-text("Benutzer"),a[href*="user-management"],a[href*="benutzerverwaltung"]
